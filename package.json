{
  "name": "@uinaf/workspace-kit",
  "version": "0.1.0",
  "description": "Config-driven agent workspace validation and scaffolding",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uinaf/workspace-kit.git"
  },
  "bin": {
    "workspace-kit": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs/convention.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "oxlint --deny-warnings",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.test.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "smoke": "node dist/cli.js --version",
    "verify": "npm run lint && npm run fmt:check && npm run typecheck && npm run test && npm run build && npm run smoke",
    "prepack": "npm run verify",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=24.18.0"
  }
}
