{
  "name": "@uinaf/workspace-kit",
  "version": "0.1.0",
  "description": "Config-driven agent workspace validation and scaffolding",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uinaf/workspace-kit.git"
  },
  "bin": {
    "workspace-kit": "dist/cli.mjs"
  },
  "files": [
    "dist",
    "docs/convention.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vp test run",
    "build": "vp pack",
    "smoke": "node dist/cli.mjs --version",
    "verify": "vp check && vp test run && vp pack && node dist/cli.mjs --version",
    "prepack": "npm run verify",
    "prepare": "vp config --no-agent || true"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^7.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5",
    "vite-plus": "0.2.5"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "^12.0.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=24.18.0"
  }
}
